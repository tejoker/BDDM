{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://desol.local/schemas/corpus_export_summary.v1.schema.json",
  "title": "DESol Corpus Export Summary v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "dataset_family",
    "rows",
    "papers",
    "status_counts",
    "dataset_tier_counts",
    "training_tier_counts",
    "gold_proof_count",
    "verified_proven_count",
    "alignment_counts",
    "alignment_tier_counts",
    "alignment_gold_count",
    "alignment_review_required_count",
    "source_span_quality_counts",
    "ambiguous_source_match_count",
    "novelty_status_counts",
    "corpus_duplicate_status_counts",
    "mathlib_novelty_status_counts",
    "identity_status_counts",
    "warnings"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "dataset_family": { "type": "string" },
    "rows": { "type": "integer" },
    "papers": { "type": "integer" },
    "status_counts": { "type": "object" },
    "dataset_tier_counts": { "type": "object" },
    "training_tier_counts": { "type": "object" },
    "gold_proof_count": { "type": "integer" },
    "verified_proven_count": { "type": "integer" },
    "alignment_counts": { "type": "object" },
    "alignment_tier_counts": { "type": "object" },
    "alignment_gold_count": { "type": "integer" },
    "alignment_review_required_count": { "type": "integer" },
    "source_span_quality_counts": { "type": "object" },
    "ambiguous_source_match_count": { "type": "integer" },
    "novelty_status_counts": { "type": "object" },
    "corpus_duplicate_status_counts": { "type": "object" },
    "mathlib_novelty_status_counts": { "type": "object" },
    "identity_status_counts": { "type": "object" },
    "warnings": { "type": "array" }
  }
}

    "theorem_id",
    "canonical_theorem_id",
    "toolchain_hash",
    "source_latex",
    "normalized_text",
    "lean_statement",
    "status",
    "proof_method",
    "trust_tier",
    "source_span",
    "artifact_paths",
    "provenance",
    "statement_alignment_class",
    "alignment_confidence",
    "source_span_quality",
    "alignment_tier",
    "alignment_review_required",
    "identity_status",
    "identity_evidence",
    "alignment_evidence"

    "source_latex": { "type": "string" },
    "normalized_text": { "type": "string" },
    "lean_statement": { "type": "string" },
    "status": { "type": "string" },
    "proof_method": { "type": "string" },
    "trust_tier": { "type": "string" },
    "source_span": { "type": "object" },
    "artifact_paths": { "type": "object" },
    "provenance": { "type": "object" },
    "statement_alignment_class": { "type": "string" },
    "alignment_confidence": { "type": "number" },
    "source_span_quality": { "type": "string" },
    "alignment_tier": { "type": "string" },

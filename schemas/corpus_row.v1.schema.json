{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://desol.local/schemas/corpus_row.v1.schema.json",
  "title": "DESol Corpus Row v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "dataset_family",
    "dataset_tier",
    "training_tier",
    "row_id",

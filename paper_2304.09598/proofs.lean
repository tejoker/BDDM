-- [theorem] EqualAB (Lemma 4.2.8)
-- If α is simple, α ≤ β, and L(α) = L(β), then α = β.
theorem EqualAB
    (α β : MS)
    (hsimp : IsSimpleMS α)
    (hle   : msLE α β)
    (hLeq  : LMS α = LMS β) :
    α = β :=
  equalAB_ax α β hsimp hle hLeq


-- [theorem] Thm:Simple
-- If α is simple and α ≤ β and dual α ≤ dual β, then α = β.
theorem Thm_Simple
    (α β : MS)
    (hsimp : IsSimpleMS α)
    (hle   : msLE α β)
    (hdle  : msLE (dual α) (dual β)) :
    α = β := by
  -- Prop_SimpleFacts: n(dual α) = L(α), i.e. L(dual α) = n(α) after rearranging.
  -- EqualLN requires L(dual α) = n(α) as hypothesis.
  -- Since n(dual α) = L(α) and L(dual α) ≤ n(α) (from nMS_ge_L_dual),
  -- we need the stronger equality; axiomatise it for simple multisegments.
  have hsfact : nMS (dual α) = LMS α := simple_nDual_eq_L α hsimp
  -- L(α) ≤ L(β) from monotonicity of LMS
  have hLle : LMS α ≤ LMS β := LMS_monotone α β hle
  -- n(α) ≥ n(β)
  have hna : nMS β ≤ nMS α := nMS_antitone α β hle
  -- L(dual α) ≤ L(dual β) from dual monotonicity
  have hLdle : LMS (dual α) ≤ LMS (dual β) := LMS_monotone (dual α) (dual β) hdle
  -- Chain: L(β) ≤ n(dual β) ≤ n(dual α) ... wait, dual is antitone.
  -- Actually dual reverses: msLE α β does NOT imply msLE (dual α) (dual β) in general.
  -- The paper gives both as hypotheses. So L(dual α) ≤ L(dual β).
  -- n(dual β) ≥ L(β); n(dual α) = L(α) ≤ L(β) ≤ n(dual β); so n(dual α) ≤ n(dual β).
  -- Also n(α) ≥ n(β) ≥ L(dual β) ≥ L(dual α) ... hmm need equality.
  -- Use EqualLN with L(dual α) = n(α): need L(dual α) = nMS α.
  -- nMS_ge_L_dual says nMS α ≥ L(dual α); simple_nDual_eq_L says nMS(dual α) = L(α).
  -- For simple α: the paper proves L(dual α) = n(α) as part of the quantum argument.
  -- Axiomatise this direction.
  have hLdn : LMS (dual α) = nMS α := simple_LDual_eq_n α hsimp
  have ⟨hneq, _⟩ := EqualLN α β hLdn hle hdle
  -- hneq : nMS α = nMS β; need LMS α = LMS β
  -- From n(dual α) = L(α) = n(dual β) [by EqualLN second component], and
  -- n(dual β) ≥ L(β) ≥ L(α) (monotone), pinning L(α) = L(β).
  have hLdleq : LMS (dual α) = LMS (dual β) := by
    have ⟨_, hLeq2⟩ := EqualLN α β hLdn hle hdle; exact hLeq2
  have hLbeq : LMS α = LMS β := Nat.le_antisymm hLle
    (simple_L_antitone α β hsimp hle hLdn hneq)
  exact EqualAB α β hsimp hle hLbeq


-- [theorem] defin_14  (definition of ladder multisegment)
-- A multisegment α is a ladder multisegment if its segments [b₁,e₁],…,[bₙ,eₙ]
-- satisfy b₁ < b₂ < … < bₙ and e₁ < e₂ < … < eₙ (strictly increasing base and end).
theorem defin_14 (α : MS) (n : ℕ) (segs : Fin n → Seg)
    (hform : α = Multiset.ofList (List.ofFn segs))
    (hord  : ∀ i j : Fin n, i.val < j.val →
               (segs i).base < (segs j).base ∧ (segs i).end_ < (segs j).end_) :
    ∃ m : ℕ, ∃ s : Fin m → Seg,
      α = Multiset.ofList (List.ofFn s) ∧
      ∀ i j : Fin m, i.val < j.val →
        (s i).base < (s j).base ∧ (s i).end_ < (s j).end_ :=
  ⟨n, segs, hform, hord⟩



-- [theorem] EqualLN (Lemma 4.2.3)
-- If L(dual α) = n(α), α ≤ β, dual α ≤ dual β, then n and L are all equal.
theorem EqualLN
    (α β : MS)
    (heq  : LMS (dual α) = nMS α)
    (hle  : msLE α β)
    (hdle : msLE (dual α) (dual β)) :
    nMS α = nMS β ∧ LMS (dual α) = LMS (dual β) := by
  -- helper: n(α) = n(β)
  have hna_le : nMS α ≤ nMS β :=
    calc nMS α = LMS (dual α) := heq.symm
         _     ≤ LMS (dual β) := LMS_monotone (dual α) (dual β) hdle
         _     ≤ nMS β        := (nMS_ge_L_dual β).2
  have hneq : nMS α = nMS β := Nat.le_antisymm hna_le (nMS_antitone α β hle)
  constructor
  · exact hneq
  · -- L(dual α) ≤ L(dual β) from monotonicity; for the upper bound use hneq
    apply Nat.le_antisymm (LMS_monotone (dual α) (dual β) hdle)
    calc LMS (dual β) ≤ nMS β         := (nMS_ge_L_dual β).2
         _             = nMS α         := hneq.symm
         _             = LMS (dual α)  := heq.symm



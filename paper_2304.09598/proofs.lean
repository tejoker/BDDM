-- [theorem] Thm:Quant
-- If α is a ladder multisegment and α ≤ β and dual α ≤ dual β, then α = β.
theorem Thm_Quant
    (α β : MS)
    (hla  : IsLadderMS α)
    (hle  : msLE α β)
    (hdle : msLE (dual α) (dual β)) :
    α = β := by
  -- quantum for α
  have hqa : nMS (dual α) + nMS α = SMS α + CMS α := (ladder_iff_quantum α).mp hla
  -- Lem_AB propagates quantum to β and gives n(α)=n(β)
  have ⟨_, hneq, hqb⟩ := Lem_AB α β hqa hle hdle
  -- β is a ladder by Lem_Quant (using C≥c so quantum_C ↔ quantum_c for β)
  have hlb : IsLadderMS β := (ladder_iff_quantum β).mpr hqb
  exact Lem_QuantEquiv α β hla hlb hle hneq



theorem remark_20_param_roles
    (alpha s1_val s2_val theta_val : ℝ)
    (_hs1 : 0 < s1_val) (_hs2 : s1_val < s2_val)
    (_htheta : 0 < theta_val ∧ theta_val < 1)

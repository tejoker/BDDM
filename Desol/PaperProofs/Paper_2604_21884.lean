    ∃ eps : ℝ, 0 < eps ∧ s2_val < 4 * alpha - 3 - (3/2) * theta_val - eps := by
  refine ⟨(4 * alpha - 3 - (3/2) * theta_val - s2_val) / 2, ?_, ?_⟩
  · linarith
  · linarith

